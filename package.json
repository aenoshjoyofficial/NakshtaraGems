{
  "name": "nakshtara-gems-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "dev:user": "npm run dev --workspace=apps/user",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  }
}
